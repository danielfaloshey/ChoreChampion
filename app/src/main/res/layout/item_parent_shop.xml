<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.github.com/apk/res-auto"
    android:id="@+id/parent_shop_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#EAEAEA"
    app:strokeColor="@color/black"
    app:strokeWidth="4dp"
    tools:ignore="NamespaceTypo">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/shop_price_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/shop_item_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/irishgrover_regular"
                    android:text="@string/shop_item_cost"
                    android:textColor="#8DBA23"
                    android:textSize="22sp"
                    tools:ignore="TextContrastCheck" />
            </LinearLayout>

            <TextView
                android:id="@+id/shop_item_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/shop_price_container"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:text="@string/shop_item_title_default"
                android:fontFamily="@font/macondo"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="@color/black"/>

        </RelativeLayout>

        <TextView
            android:id="@+id/shop_item_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:fontFamily="@font/macondo"
            android:textStyle="bold"
            android:textColor="@color/red"
            android:textSize="18sp"
            android:layout_marginTop="4dp"
            android:text="@string/shop_item_desc_default" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>