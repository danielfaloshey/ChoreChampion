<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true">

    <ImageView
        android:id="@+id/parent_shop_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/shop_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/shop_new"
        tools:ignore="ImageContrastCheck" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:padding="16dp">

        <TextView
            android:id="@+id/shop_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shop_title"
            android:fontFamily="@font/irishgrover_regular"
            android:textSize="36sp"
            android:textColor="@color/white"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="450dp"
            app:cardUseCompatPadding="true"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:strokeColor="#40FFFFFF"
            app:strokeWidth="2dp"
            app:cardBackgroundColor="@color/glassWhite">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/parent_shop_grid"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="16dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <LinearLayout
            android:id="@+id/shop_btn_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shop_add_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:elevation="12dp"
                app:cornerRadius="4dp"
                android:text="@string/add_button"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/irishgrover_regular"
                android:textSize="24sp"
                android:backgroundTint="@color/forest_green"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shop_edit_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cornerRadius="4dp"
                android:layout_marginStart="8dp"
                android:elevation="12dp"
                android:text="@string/edit_button"
                android:fontFamily="@font/irishgrover_regular"
                android:textSize="24sp"
                android:backgroundTint="@color/red"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/shop_msg"
            android:fontFamily="@font/macondo"
            android:textSize="20sp"
            android:textColor="@color/white"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/parent_shop_info"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="0dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:backgroundTint="@color/glassWhite"
        app:icon="@drawable/ic_info"
        app:iconSize="24dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@color/white"
        android:importantForAccessibility="no" />

</FrameLayout>