<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true">

    <ImageView
        android:id="@+id/pin_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/pin_background_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/vault"
        tools:ignore="ImageContrastCheck" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/pin_back_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/back_button"
        android:textSize="18sp"
        android:backgroundTint="@android:color/transparent"
        android:fontFamily="@font/macondo"
        app:icon="@drawable/ic_back_arrow"
        app:iconGravity="start"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:padding="16dp">

        <TextView
            android:id="@+id/pin_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pin_title"
            android:fontFamily="@font/irishgrover_regular"
            android:textSize="32sp"
            android:textColor="@color/white"/>


        <LinearLayout
            android:id="@+id/pin_box_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:padding="16dp">

            <EditText
                android:id="@+id/pin_box1"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/pin_box_background"
                android:gravity="center"
                android:imeOptions="actionNext"
                android:importantForAutofill="no"
                android:inputType="numberPassword"
                android:maxLength="1"
                tools:ignore="LabelFor,SpeakableTextPresentCheck" />

            <EditText
                android:id="@+id/pin_box2"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:importantForAutofill="no"
                android:layout_marginStart="12dp"
                android:maxLength="1"
                android:inputType="numberPassword"
                android:imeOptions="actionNext"
                android:background="@drawable/pin_box_background"
                tools:ignore="LabelFor, SpeakableTextPresentCheck" />

            <EditText
                android:id="@+id/pin_box3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:layout_marginStart="12dp"
                android:importantForAutofill="no"
                android:maxLength="1"
                android:inputType="numberPassword"
                android:imeOptions="actionNext"
                android:background="@drawable/pin_box_background"
                tools:ignore="LabelFor, SpeakableTextPresentCheck" />

            <EditText
                android:id="@+id/pin_box4"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:layout_marginStart="12dp"
                android:importantForAutofill="no"
                android:maxLength="1"
                android:inputType="numberPassword"
                android:imeOptions="actionDone"
                android:background="@drawable/pin_box_background"
                tools:ignore="LabelFor, SpeakableTextPresentCheck" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/enter_pin_btn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/red"
            android:fontFamily="@font/irishgrover_regular"
            android:text="@string/enter_btn"
            android:textSize="18sp"
            app:cornerRadius="4dp"
            android:elevation="12dp"
            android:stateListAnimator="@animator/button_pop"
            tools:ignore="TextContrastCheck" />

    </LinearLayout>
</FrameLayout>