<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true">

    <ImageView
        android:id="@+id/avatar_selection_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/avatar_background_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/avatar_choice"
        tools:ignore="ImageContrastCheck" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:padding="16dp">

        <TextView
            android:id="@+id/avatar_selection_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/avatar_selection_title"
            android:fontFamily="@font/irishgrover_regular"
            android:textSize="30sp"
            android:textColor="@color/white"/>

        <Spinner
            android:id="@+id/class_selector_spinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:spinnerMode="dropdown"
            android:padding="8dp"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/spinner_background"
            android:popupBackground="@drawable/spinner_popup_background"/>


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:strokeColor="#40FFFFFF"
            app:strokeWidth="2dp"
            app:cardBackgroundColor="@color/glassWhite">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/avatar_icon_recycler"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:padding="16dp"
                android:clipToPadding="false"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/avatar_done_btn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/new_blue"
            android:fontFamily="@font/irishgrover_regular"
            android:text="@string/done_button"
            android:textColor="@color/white"
            android:textSize="24sp"
            app:cornerRadius="4dp"
            tools:ignore="TextContrastCheck" />

        <TextView
            android:id="@+id/icon_credits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/icon_credit"
            android:fontFamily="@font/macondo"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </LinearLayout>

</FrameLayout>