<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true">

    <ImageView
        android:id="@+id/parent_quests_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/quests_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/guild_new"
        tools:ignore="ImageContrastCheck" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:padding="16dp">

        <TextView
            android:id="@+id/quests_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quests_title"
            android:fontFamily="@font/irishgrover_regular"
            android:textSize="36sp"
            android:textColor="@color/white"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:strokeColor="#40FFFFFF"
            app:strokeWidth="2dp"
            app:cardBackgroundColor="@color/glassWhite">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/parent_quest_grid"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:padding="16dp"
                android:clipToPadding="false"/>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/quest_btn_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quest_add_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:elevation="12dp"
                android:text="@string/add_button"
                android:layout_marginEnd="8dp"
                app:cornerRadius="4dp"
                android:fontFamily="@font/irishgrover_regular"
                android:textSize="24sp"
                android:backgroundTint="@color/forest_green"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quest_edit_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:elevation="12dp"
                app:cornerRadius="4dp"
                android:text="@string/edit_button"
                android:fontFamily="@font/irishgrover_regular"
                android:textSize="24sp"
                android:backgroundTint="@color/red"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/quests_msg"
            android:fontFamily="@font/macondo"
            android:textSize="20sp"
            android:textColor="@color/white"/>

    </LinearLayout>

</FrameLayout>