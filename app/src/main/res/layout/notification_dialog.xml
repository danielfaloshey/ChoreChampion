<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/new_blue"
        app:strokeWidth="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <TextView
                android:id="@+id/dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notifications_title"
                android:textAllCaps="true"
                android:fontFamily="@font/irishgrover_regular"
                android:shadowColor="@color/new_blue"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="6"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/dialog_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notifs_subtitle"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:layout_marginTop="2dp"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/macondo"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/notifications_recycler"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:scrollbars="vertical"
                android:overScrollMode="ifContentScrolls" />

            <TextView
                android:id="@+id/empty_notifications_text"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:text="@string/empty_notifs"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:fontFamily="@font/macondo"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_all"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxWidth="300dp"
                    android:layout_marginEnd="8dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/macondo"
                    android:layout_weight="1"
                    android:text="@string/clear_button"
                    android:textColor="#D32F2F"
                    app:cornerRadius="12dp"
                    app:rippleColor="#1AFA4238"
                    app:strokeColor="#E53935"
                    android:stateListAnimator="@animator/button_pop"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_close_notifs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:maxWidth="300dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/new_blue"
                    android:textStyle="bold"
                    android:fontFamily="@font/macondo"
                    android:textAllCaps="true"
                    android:text="@string/exit_notifs"
                    android:textColor="#37474F"
                    app:cornerRadius="12dp"
                    android:stateListAnimator="@animator/button_pop"/>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>