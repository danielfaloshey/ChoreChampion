<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:strokeColor="#40FFFFFF"
    app:strokeWidth="2dp"
    app:cardBackgroundColor="@color/glassWhite">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/info_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quest_board_guide"
            android:fontFamily="@font/irishgrover_regular"
            android:textSize="26sp"
            android:textColor="@color/black"
            android:shadowColor="@color/new_blue"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/info_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/info_message_default"
            android:fontFamily="@font/macondo"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/info_close_btn"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/forest_green"
            android:fontFamily="@font/irishgrover_regular"
            android:stateListAnimator="@animator/button_pop"
            android:text="@string/got_it_btn_text"
            android:textSize="18sp"
            app:cornerRadius="8dp"
            tools:ignore="TextContrastCheck" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>