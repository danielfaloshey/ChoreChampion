<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfetti_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/new_blue"
        app:strokeWidth="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
            android:id="@+id/rewards_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/congrats_title"
            android:padding="16dp"
            android:textStyle="bold"
            android:textSize="32sp"
            android:fontFamily="@font/irishgrover_regular"
            android:shadowColor="@color/red"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6"/>

            <ImageView
                android:id="@+id/rewardIcon"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/crossed_swords"
                android:importantForAccessibility="no"/>

            <TextView
                android:id="@+id/reward_dialog_gold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/irishgrover_regular"
                android:padding="16dp"
                android:text="@string/rewards_gold"
                android:textColor="#8DBA23"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:ignore="TextContrastCheck"
                android:shadowColor="@color/black"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="6"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/close_reward_dialog"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/forest_green"
                android:fontFamily="@font/irishgrover_regular"
                android:text="@string/awesome"
                android:textSize="18sp"
                app:cornerRadius="8dp"
                tools:ignore="TextContrastCheck" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>