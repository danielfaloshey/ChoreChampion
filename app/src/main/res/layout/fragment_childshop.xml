<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true">

    <ImageView
        android:id="@+id/child_shop_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/shop_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/shop_new"
        tools:ignore="ImageContrastCheck" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/bottom_nav_height">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_vertical"
            android:gravity="center_horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/shop_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shop_title"
                android:fontFamily="@font/irishgrover_regular"
                android:textSize="48sp"
                android:textColor="@color/white"
                android:shadowColor="@color/black"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="6"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                app:cardUseCompatPadding="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/glassWhite">

                <TextView
                    android:id="@+id/current_gold_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_gold_default"
                    android:layout_gravity="center"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:shadowColor="@color/white"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="6"
                    android:fontFamily="@font/medieval_sharp"/>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                app:cardUseCompatPadding="true"
                app:cardCornerRadius="24dp"
                app:cardElevation="16dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/glassWhite">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/child_shop_grid"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:clipToPadding="false"
                        android:scrollbars="vertical"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buy_btn"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/buy_button"
                android:textSize="24sp"
                android:textColor="@color/white"
                app:cornerRadius="4dp"
                android:elevation="12dp"
                android:shadowColor="@color/black"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="6"
                android:stateListAnimator="@animator/button_pop"
                android:fontFamily="@font/irishgrover_regular"
                android:backgroundTint="@color/forest_green"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/child_shop_info"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="0dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:backgroundTint="@color/glassWhite"
        app:icon="@drawable/ic_info"
        app:iconSize="24dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@color/white"
        android:importantForAccessibility="no"
        tools:ignore="VisualLintSystemUi" />
</FrameLayout>